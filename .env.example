# Repository-level example only. The app reads most settings from its UI/database.
# Copy app-specific values from vedio_summary_v1/.env.example when needed.

# Optional: force the Python runtime used by local mlx-whisper fallback.
MLX_WHISPER_PYTHON=/absolute/path/to/.venv/bin/python

# Optional: OpenAI-compatible API credentials can be exported in your shell,
# then pasted into the app settings page or read by local tooling.
OPENAI_API_KEY=replace-with-your-local-secret
DASHSCOPE_API_KEY=replace-with-your-local-secret

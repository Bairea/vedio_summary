# Optional local environment variables for development.
# Do not put real secrets in committed files.

# Force Python runtime for local MLX Whisper fallback.
MLX_WHISPER_PYTHON=/absolute/path/to/.venv/bin/python

# Optional OpenAI-compatible credentials for local shell workflows.
# The app settings page also stores AI configuration in .data/app.db.
OPENAI_API_KEY=replace-with-your-local-secret
DASHSCOPE_API_KEY=replace-with-your-local-secret

# Optional server port overrides, if introduced by deployment/runtime wrappers.
PORT=3001
